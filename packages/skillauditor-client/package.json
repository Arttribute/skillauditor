{
  "name": "@skillauditor/client",
  "version": "0.2.3",
  "description": "Agent SDK for SkillAuditor — submit, verify, and check skills onchain in one call",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Arttribute/skillauditor.git",
    "directory": "packages/skillauditor-client"
  },
  "keywords": ["skillauditor", "skill", "agent", "sdk", "ens", "onchain", "worldcoin"],
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "skillauditor": "./dist/cli.js",
    "skillauditor-client": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@worldcoin/agentkit": "^0.1.6",
    "viem": "^2.47.10",
    "x402": "^0.7.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "typescript": "^5.8.3"
  }
}
